post {
  url: {{base_url}}/api/v1/master/{{master_id}}/location
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "latitude": 37.952321,
    "longitude": 58.382345,
